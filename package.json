{
  "name": "one-shot-template",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "preflight": "node scripts/preflight.mjs",
    "prebuild": "node scripts/preflight.mjs && tsc --noEmit",
    "test:watch": "vitest",
    "postinstall": "intent install --no-prompt || true"
  },
  "dependencies": {
    "@radix-ui/react-toast": "^1.2.0",
