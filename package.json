    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4",
    "zod": "^3.25",
    "@tanstack/start-client-core": "*",
    "@durable-streams/aisdk-transport": "^0.0.3",
    "@durable-streams/client": "^0.2",
